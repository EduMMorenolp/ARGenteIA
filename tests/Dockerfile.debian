# Test: Debian 12 con Node.js (instalación completa de instalar.sh)
FROM node:22-slim

RUN apt-get update && apt-get install -y \
    git \
    python3 \
    make \
    g++ \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY . .
RUN chmod +x instalar.sh tests/test-install-linux.sh

CMD ["bash", "tests/test-install-linux.sh"]
